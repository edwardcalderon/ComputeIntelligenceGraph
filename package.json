{
  "name": "cig-monorepo",
  "version": "0.2.67",
  "private": true,
  "license": "MIT",
  "description": "Compute Intelligence Graph - monorepo root",
  "scripts": {
    "env:sync": "pnpm exec versioning env sync",
    "env:doctor": "pnpm exec versioning env doctor",
    "env:validate": "pnpm exec versioning env validate --all",
    "build": "pnpm env:sync && pnpm --recursive build",
    "dev": "pnpm env:sync && pnpm --filter @cig/dashboard dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && versioning cleanup",
    "version:sync": "versioning sync",
    "version:validate": "versioning validate",
    "version:validate:release": "bash scripts/validate-release-ref.sh",
    "version:status": "versioning status",
    "version:bump:patch": "versioning patch",
    "version:bump:minor": "versioning minor",
    "version:bump:major": "versioning major",
    "version:changelog": "versioning changelog",
    "check:secrets": "versioning check-secrets",
    "test:api-impact": "node --test scripts/api-impact.test.mjs",
    "test:release-version": "node --test scripts/validate-release-version.test.mjs && bash scripts/validate-release-ref.test.sh",
    "release": "./scripts/release.sh release",
    "release:build": "./scripts/release.sh release",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "release:dry": "./scripts/release.sh patch --dry-run",
    "release:dry:build": "./scripts/release.sh release --dry-run",
    "prepare": "husky || true",
    "prepublishOnly": "versioning validate",
    "dev:dashboard": "pnpm env:sync && node scripts/check-ports.js 3001 && PORT=3001 pnpm --filter @cig/dashboard dev",
    "dev:landing": "pnpm env:sync && node scripts/check-ports.js 3000 && PORT=3000 pnpm --filter @cig/landing dev",
    "dev:wizard-ui": "pnpm env:sync && node scripts/check-ports.js 3002 && PORT=3002 pnpm --filter @cig/wizard-ui dev",
    "dev:api": "pnpm env:sync && node scripts/check-ports.js 3003 && pnpm --filter @cig/api dev",
    "dev:agents": "pnpm env:sync && pnpm --filter @cig/agents dev",
    "dev:chatbot": "pnpm env:sync && pnpm --filter @cig/chatbot dev",
    "dev:cli": "pnpm env:sync && pnpm --filter @cig-technology/cli dev",
    "dev:config": "pnpm env:sync && pnpm --filter @cig/config dev",
    "dev:discovery": "pnpm env:sync && pnpm --filter @cig/discovery dev",
    "dev:graph": "pnpm env:sync && pnpm --filter @cig/graph dev",
    "dev:sdk": "pnpm env:sync && pnpm --filter @cig/sdk dev",
    "dev:docs": "pnpm env:sync && node scripts/check-ports.js 3004 && PORT=3004 pnpm --filter @cig/docs dev",
    "dev:all": "pnpm env:sync && node scripts/check-ports.js 3000 3001 3002 3003 3004 && concurrently --names \"dashboard,landing,wizard,api,agents,chatbot,cli,config,discovery,graph,sdk,docs\" --prefix-colors \"cyan.bold,magenta.bold,yellow.bold,green.bold,blue.bold,red.bold,white.bold,gray.bold,greenBright.bold,blueBright.bold,yellowBright.bold,whiteBright.bold\" \"PORT=3001 pnpm --filter @cig/dashboard dev\" \"PORT=3000 pnpm --filter @cig/landing dev\" \"PORT=3002 pnpm --filter @cig/wizard-ui dev\" \"PORT=3003 pnpm --filter @cig/api dev\" \"pnpm --filter @cig/agents dev\" \"pnpm --filter @cig/chatbot dev\" \"pnpm --filter @cig-technology/cli dev\" \"pnpm --filter @cig/config dev\" \"pnpm --filter @cig/discovery dev\" \"pnpm --filter @cig/graph dev\" \"pnpm --filter @cig/sdk dev\" \"PORT=3004 pnpm --filter @cig/docs dev\"",
    "build:dashboard": "pnpm env:sync && pnpm --filter @cig/dashboard build",
    "build:landing": "pnpm env:sync && pnpm --filter @cig/landing build",
    "build:wizard-ui": "pnpm env:sync && pnpm --filter @cig/wizard-ui build",
    "build:api": "pnpm env:sync && pnpm --filter @cig/api build",
    "build:agents": "pnpm env:sync && pnpm --filter @cig/agents build",
    "build:chatbot": "pnpm env:sync && pnpm --filter @cig/chatbot build",
    "build:cli": "pnpm env:sync && pnpm --filter @cig-technology/cli build",
    "build:config": "pnpm env:sync && pnpm --filter @cig/config build",
    "build:discovery": "pnpm env:sync && pnpm --filter @cig/discovery build",
    "build:graph": "pnpm env:sync && pnpm --filter @cig/graph build",
    "build:sdk": "pnpm env:sync && pnpm --filter @cig/sdk build",
    "build:docs": "pnpm env:sync && pnpm --filter @cig/docs build",
    "build:i18n": "pnpm --filter @cig/i18n build",
    "i18n:check": "node packages/i18n/scripts/check-translations.mjs",
    "i18n:extract": "node packages/i18n/scripts/extract.mjs",
    "i18n:compile": "node packages/i18n/scripts/compile-catalogs.mjs",
    "i18n:release:patch": "cd packages/i18n && bash scripts/release.sh patch",
    "i18n:release:minor": "cd packages/i18n && bash scripts/release.sh minor",
    "i18n:release:major": "cd packages/i18n && bash scripts/release.sh major",
    "i18n:release:dry": "cd packages/i18n && bash scripts/release.sh --dry-run patch",
    "cli:release:patch": "cd packages/cli && bash scripts/release.sh patch",
    "cli:release:minor": "cd packages/cli && bash scripts/release.sh minor",
    "cli:release:major": "cd packages/cli && bash scripts/release.sh major",
    "cli:release:prerelease": "cd packages/cli && bash scripts/release.sh prerelease beta",
    "cli:release:dry": "cd packages/cli && bash scripts/release.sh --dry-run patch",
    "build:all": "pnpm env:sync && pnpm --recursive build",
    "__workspace_scripts_managed": "[\"dev:dashboard\",\"dev:landing\",\"dev:wizard-ui\",\"dev:api\",\"dev:agents\",\"dev:chatbot\",\"dev:cli\",\"dev:config\",\"dev:discovery\",\"dev:graph\",\"dev:sdk\",\"dev:all\",\"dev\",\"build:dashboard\",\"build:landing\",\"build:wizard-ui\",\"build:api\",\"build:agents\",\"build:chatbot\",\"build:cli\",\"build:config\",\"build:discovery\",\"build:graph\",\"build:sdk\",\"build:all\",\"build\"]"
  },
  "devDependencies": {
    "@edcalderon/versioning": "^1.5.5",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
