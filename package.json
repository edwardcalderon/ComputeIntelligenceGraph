{
  "name": "cig-monorepo",
  "version": "0.1.3",
  "private": true,
  "license": "MIT",
  "description": "Compute Intelligence Graph - monorepo root",
  "scripts": {
    "build": "pnpm --recursive build",
    "dev": "pnpm --filter @cig/dashboard dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && versioning cleanup",
    "version:sync": "versioning sync",
    "version:validate": "versioning validate",
    "version:status": "versioning status",
    "version:bump:patch": "versioning patch",
    "version:bump:minor": "versioning minor",
    "version:bump:major": "versioning major",
    "version:changelog": "versioning changelog",
    "check:secrets": "versioning check-secrets",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "release:dry": "./scripts/release.sh patch --dry-run",
    "prepublishOnly": "versioning validate",
    "dev:dashboard": "pnpm --filter @cig/dashboard dev",
    "dev:landing": "pnpm --filter @cig/landing dev",
    "dev:wizard-ui": "pnpm --filter @cig/wizard-ui dev",
    "dev:api": "pnpm --filter @cig/api dev",
    "dev:agents": "pnpm --filter @cig/agents dev",
    "dev:chatbot": "pnpm --filter @cig/chatbot dev",
    "dev:cli": "pnpm --filter @cig/cli dev",
    "dev:config": "pnpm --filter @cig/config dev",
    "dev:discovery": "pnpm --filter @cig/discovery dev",
    "dev:graph": "pnpm --filter @cig/graph dev",
    "dev:sdk": "pnpm --filter @cig/sdk dev",
    "dev:all": "concurrently \"pnpm --filter @cig/dashboard dev\" \"pnpm --filter @cig/landing dev\" \"pnpm --filter @cig/wizard-ui dev\" \"pnpm --filter @cig/api dev\" \"pnpm --filter @cig/agents dev\" \"pnpm --filter @cig/chatbot dev\" \"pnpm --filter @cig/cli dev\" \"pnpm --filter @cig/config dev\" \"pnpm --filter @cig/discovery dev\" \"pnpm --filter @cig/graph dev\" \"pnpm --filter @cig/sdk dev\"",
    "build:dashboard": "pnpm --filter @cig/dashboard build",
    "build:landing": "pnpm --filter @cig/landing build",
    "build:wizard-ui": "pnpm --filter @cig/wizard-ui build",
    "build:api": "pnpm --filter @cig/api build",
    "build:agents": "pnpm --filter @cig/agents build",
    "build:chatbot": "pnpm --filter @cig/chatbot build",
    "build:cli": "pnpm --filter @cig/cli build",
    "build:config": "pnpm --filter @cig/config build",
    "build:discovery": "pnpm --filter @cig/discovery build",
    "build:graph": "pnpm --filter @cig/graph build",
    "build:sdk": "pnpm --filter @cig/sdk build",
    "build:all": "pnpm --recursive build",
    "__workspace_scripts_managed": "[\"dev:dashboard\",\"dev:landing\",\"dev:wizard-ui\",\"dev:api\",\"dev:agents\",\"dev:chatbot\",\"dev:cli\",\"dev:config\",\"dev:discovery\",\"dev:graph\",\"dev:sdk\",\"dev:all\",\"dev\",\"build:dashboard\",\"build:landing\",\"build:wizard-ui\",\"build:api\",\"build:agents\",\"build:chatbot\",\"build:cli\",\"build:config\",\"build:discovery\",\"build:graph\",\"build:sdk\",\"build:all\",\"build\"]"
  },
  "devDependencies": {
    "@edcalderon/versioning": "^1.4.7",
    "concurrently": "^9.2.1",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
