# Generated by @edcalderon/versioning workspace-env. Do not edit directly.
# Canonical root env example

# AWS Secrets Manager ARN for the API OpenAI key
API_OPENAI_API_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-2:123456789012:secret:cig/api/openai
# Internal API URL for agent packages
API_URL=http://localhost:8080
# Authentik admin email
AUTHENTIK_ADMIN_EMAIL=<YOUR_AUTHENTIK_ADMIN_EMAIL>
# Authentik domain
AUTHENTIK_DOMAIN=<YOUR_AUTHENTIK_DOMAIN>
# Authentik OIDC issuer URL
AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/cig/
# Authentik JWKS endpoint for ID token signature verification
AUTHENTIK_JWKS_URI=https://auth.example.com/application/o/cig/jwks/
# Authentik subnet ID
AUTHENTIK_SUBNET_ID=subnet-1234567890
# Authentik OIDC token endpoint
AUTHENTIK_TOKEN_ENDPOINT=https://auth.example.com/application/o/token/
# Authentik VPC ID
AUTHENTIK_VPC_ID=vpc-1234567890
# AWS account ID
AWS_ACCOUNT_ID=123456789012
# AWS CLI profile
AWS_PROFILE=default
# AWS region
AWS_REGION=us-east-2
# AWS role ARN
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/cig
# Cartography service URL
CARTOGRAPHY_URL=http://localhost:8001
# Chroma vector database URL
CHROMA_URL=http://localhost:8000
# Comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Whether dashboard integrates with Authentik
DASHBOARD_AUTHENTIK_INTEGRATION=true
# Dashboard build output path
DASHBOARD_BUILD_PATH=./apps/dashboard/out
# Dashboard domain
DASHBOARD_DOMAIN=dashboard.example.com
# Discovery interval in minutes
DISCOVERY_INTERVAL_MINUTES=5
# Discovery interval in milliseconds
DISCOVERY_INTERVAL_MS=300000
# GCP project ID
GCP_PROJECT=your-gcp-project
# Google OAuth client ID
GOOGLE_AUTH_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>.apps.googleusercontent.com
# Google OAuth client secret
GOOGLE_AUTH_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
# API host binding
HOST=0.0.0.0
# Compute module name
IAC_COMPUTE_MODULE=compute
# Terraform modules base path
IAC_MODULES_PATH=./packages/iac/modules
# Networking module name
IAC_NETWORKING_MODULE=networking
# JWT signing secret
JWT_SECRET=<YOUR_JWT_SECRET>
# Enable the legacy GitHub Pages base path
LEGACY_BASEPATH=false
# Application log level
LOG_LEVEL=info
# Whether structured logs include timestamps
LOG_TIMESTAMPS=true
# Neo4j database name
NEO4J_DATABASE=neo4j
# Neo4j password
NEO4J_PASSWORD=neo4j
# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687
# Neo4j username
NEO4J_USER=neo4j
# Public API URL for browser apps
NEXT_PUBLIC_API_URL=http://localhost:8080
# Dashboard URL — where to redirect after a successful sign-in
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
# Legacy public site URL
NEXT_PUBLIC_LEGACY_SITE_URL=https://edwardcalderon.github.io/ComputeIntelligenceGraph
# Primary public site URL
NEXT_PUBLIC_SITE_URL=https://cig.lat
# OIDC client ID registered in Authentik
OIDC_CLIENT_ID=your-oidc-client-id
# OIDC client secret
OIDC_CLIENT_SECRET=your-oidc-client-secret
# OIDC redirect URI for the API callback
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback
# OpenAI API key
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# API port
PORT=8080
# Canonical Supabase anon key for frontend consumers
SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
# Direct database connection string
SUPABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Direct database connection string used for migrations
SUPABASE_DIRECT_URL_MIGRATIONS=postgresql://postgres:postgres@localhost:5432/postgres
# IPv4-only pooler connection string (avoids ENETUNREACH on IPv6-unreachable networks)
SUPABASE_DIRECT_URL_POOLER=postgresql://postgres.ref:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres
# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SUPABASE_SERVICE_ROLE_KEY>
# Canonical Supabase URL for frontend consumers
SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
