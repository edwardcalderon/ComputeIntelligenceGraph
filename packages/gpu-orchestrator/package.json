{
  "name": "@gpu-orchestrator/app",
  "version": "0.1.0",
  "description": "Standalone GPU compute session orchestrator for Ollama-based LLM inference",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/cli.js",
  "bin": {
    "gpu-orchestrator": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build --force",
    "dev": "tsc --build --watch --preserveWatchOutput --force",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js start",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "googleapis": "^144.0.0",
    "zod": "^3.25.8",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "fast-check": "^3.23.2",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
