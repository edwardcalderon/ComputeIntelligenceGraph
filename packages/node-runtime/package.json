{
  "name": "@cig/node-runtime",
  "version": "0.1.36",
  "description": "Persistent Linux-first CIG node runtime",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cig-node": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter @cig/runtime-contracts build && tsc",
    "dev": "pnpm --filter @cig/runtime-contracts build && tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cig/discovery": "workspace:*",
    "@cig/runtime-contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
