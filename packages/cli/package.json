{
  "name": "@cig-technology/cli",
  "version": "0.1.60",
  "description": "Production-oriented CLI for bootstrapping and operating CIG nodes and self-hosted installs",
  "keywords": [
    "cig",
    "cli",
    "cloud",
    "infrastructure",
    "graph",
    "security",
    "devops"
  ],
  "license": "MIT",
  "author": "Edward Calderon <edward@cig.lat>",
  "repository": {
    "type": "git",
    "url": "https://github.com/edwardcalderon/ComputeIntelligenceGraph.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/edwardcalderon/ComputeIntelligenceGraph/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/edwardcalderon/ComputeIntelligenceGraph/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "cig": "dist/index.js"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "version:status": "versioning status -c versioning.config.json",
    "version:validate": "versioning validate -c versioning.config.json && npm run version:guard:readme",
    "version:sync": "versioning sync -c versioning.config.json",
    "version:update-readme": "node scripts/sync-readme.mjs",
    "version:guard:readme": "node scripts/guard-readme.mjs",
    "version:bump:patch": "versioning patch -c versioning.config.json --no-commit --no-tag",
    "version:bump:minor": "versioning minor -c versioning.config.json --no-commit --no-tag",
    "version:bump:major": "versioning major -c versioning.config.json --no-commit --no-tag",
    "version:bump:prerelease": "versioning bump prerelease --pre-release beta -c versioning.config.json --no-commit --no-tag",
    "publish:npm": "versioning publish-package --tag latest",
    "publish:npm:dry": "versioning publish-package --dry-run --tag latest",
    "prepublishOnly": "npm run version:validate && npm run build && npm run test"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.0.0"
  },
  "devDependencies": {
    "@edcalderon/versioning": "^1.5.5",
    "@types/node": "^20.0.0",
    "fast-check": "^3.23.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
