#!/bin/bash
set -euo pipefail

REGION="${region}"
DOMAIN="${domain}"
SECRET_PREFIX="${secret_prefix}"
API_IMAGE_URI="${api_image_uri}"
API_CONTAINER_PORT="${api_container_port}"
NEO4J_VERSION="${neo4j_version}"
CORS_ORIGINS="${cors_origins}"
SMTP_HOST="${smtp_host}"
SMTP_PORT="${smtp_port}"
SMTP_SECURE="${smtp_secure}"
SMTP_AUTH_ENABLED="${smtp_auth_enabled}"
SMTP_FROM_EMAIL_SECRET_SUFFIX="${smtp_from_email}"
SMTP_USER_DEFAULT="${smtp_user}"
SMTP_OTP_SUBJECT="${smtp_otp_subject}"

dnf update -y
dnf install -y awscli docker jq xfsprogs
systemctl enable --now docker

mkdir -p /usr/local/lib/docker/cli-plugins
curl -fsSL "https://github.com/docker/compose/releases/download/v2.27.1/docker-compose-linux-x86_64" \
  -o /usr/local/lib/docker/cli-plugins/docker-compose
chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

mkdir -p /opt/cig /srv/neo4j/logs

ATTACHMENT_DEVICE="/dev/xvdf"
DEVICE_NAME=""

for attempt in $(seq 1 30); do
  if [ -b /dev/nvme1n1 ]; then
    DEVICE_NAME="/dev/nvme1n1"
    break
  fi

  if [ -b "$ATTACHMENT_DEVICE" ]; then
    DEVICE_NAME="$ATTACHMENT_DEVICE"
    break
  fi

  sleep 2
done

if [ -z "$DEVICE_NAME" ]; then
  echo "Neo4j data device was not attached in time" >&2
  exit 1
fi

if ! blkid "$DEVICE_NAME" >/dev/null 2>&1; then
  mkfs -t xfs "$DEVICE_NAME"
fi

if ! mountpoint -q /srv/neo4j; then
  mount "$DEVICE_NAME" /srv/neo4j
fi

UUID=$(blkid -s UUID -o value "$DEVICE_NAME")
grep -q "$UUID" /etc/fstab || echo "UUID=$UUID /srv/neo4j xfs defaults,nofail 0 2" >> /etc/fstab

cat > /opt/cig/Caddyfile <<CADDY
$DOMAIN {
  encode zstd gzip
  reverse_proxy api:$API_CONTAINER_PORT
}
CADDY

cat > /usr/local/bin/cig-api-refresh <<'REFRESH'
#!/bin/bash
set -euo pipefail

REGION="${region}"
SECRET_PREFIX="${secret_prefix}"
SMTP_FROM_EMAIL_SECRET_SUFFIX="${smtp_from_email}"
SMTP_USER_DEFAULT="${smtp_user}"
IMAGE_URI_FILE="/opt/cig/api-image-uri"
API_ENV_FILE="/opt/cig/api.env"
COMPOSE_FILE="/opt/cig/docker-compose.yml"

if [ ! -f "$IMAGE_URI_FILE" ]; then
  echo "Missing image URI file: $IMAGE_URI_FILE" >&2
  exit 1
fi

API_IMAGE_URI="$(tr -d '[:space:]' < "$IMAGE_URI_FILE")"
if [ -z "$API_IMAGE_URI" ]; then
  echo "API image URI is empty" >&2
  exit 1
fi

ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text)"
aws ecr get-login-password --region "$REGION" \
  | docker login --username AWS --password-stdin \
    "$${ACCOUNT_ID}.dkr.ecr.$${REGION}.amazonaws.com"

secret() {
  aws secretsmanager get-secret-value \
    --secret-id "$${SECRET_PREFIX}$1" \
    --region "$REGION" \
    --query SecretString \
    --output text
}

DATABASE_URL="$(secret database-url)"
JWT_SECRET="$(secret jwt-secret)"
OPENAI_API_KEY="$(secret openai-api-key)"
AUTHENTIK_ISSUER_URL="$(secret authentik-issuer-url)"
AUTHENTIK_JWKS_URI="$(secret authentik-jwks-uri)"
AUTHENTIK_TOKEN_ENDPOINT="$(secret authentik-token-endpoint)"
OIDC_CLIENT_ID="$(secret oidc-client-id)"
OIDC_CLIENT_SECRET="$(secret oidc-client-secret)"
SUPABASE_URL="$(secret supabase-url)"
SUPABASE_SERVICE_ROLE_KEY="$(secret supabase-service-role-key)"
SMTP_PASSWORD="$(secret smtp-password)"
SMTP_FROM_EMAIL="$(secret "$SMTP_FROM_EMAIL_SECRET_SUFFIX")"
SMTP_USER="$SMTP_FROM_EMAIL"
if [ -n "$SMTP_USER_DEFAULT" ]; then
  SMTP_USER="$SMTP_USER_DEFAULT"
fi
NEO4J_PASSWORD="$(secret neo4j-password)"

cat > "$API_ENV_FILE" <<ENV
API_IMAGE_URI=$API_IMAGE_URI
DATABASE_URL=$DATABASE_URL
JWT_SECRET=$JWT_SECRET
OPENAI_API_KEY=$OPENAI_API_KEY
AUTHENTIK_ISSUER_URL=$AUTHENTIK_ISSUER_URL
AUTHENTIK_JWKS_URI=$AUTHENTIK_JWKS_URI
AUTHENTIK_TOKEN_ENDPOINT=$AUTHENTIK_TOKEN_ENDPOINT
OIDC_CLIENT_ID=$OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=$OIDC_CLIENT_SECRET
SUPABASE_URL=$SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY
SMTP_HOST=${smtp_host}
SMTP_PORT=${smtp_port}
SMTP_SECURE=${smtp_secure}
SMTP_FROM_EMAIL=$SMTP_FROM_EMAIL
SMTP_AUTH_ENABLED=${smtp_auth_enabled}
SMTP_USER=$SMTP_USER
SMTP_OTP_SUBJECT=${smtp_otp_subject}
SMTP_PASSWORD=$SMTP_PASSWORD
CIG_AUTH_MODE=managed
CIG_AUTO_MIGRATE=true
CORS_ORIGINS=${cors_origins}
NEO4J_PASSWORD=$NEO4J_PASSWORD
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
PORT=${api_container_port}
HOST=0.0.0.0
ENV
chmod 600 "$API_ENV_FILE"

cat > "$COMPOSE_FILE" <<COMPOSE
services:
  neo4j:
    image: neo4j:${neo4j_version}
    restart: unless-stopped
    environment:
      NEO4J_AUTH: neo4j/$${NEO4J_PASSWORD}
      NEO4J_dbms_memory_pagecache_size: 512m
      NEO4J_dbms_memory_heap_initial__size: 512m
      NEO4J_dbms_memory_heap_max__size: 1g
    volumes:
      - neo4j_data:/data
      - /srv/neo4j/logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "cypher-shell -u neo4j -p $${NEO4J_PASSWORD} 'RETURN 1' >/dev/null 2>&1"]
      interval: 30s
      timeout: 10s
      retries: 10

  api:
    image: $${API_IMAGE_URI}
    restart: unless-stopped
    env_file:
      - /opt/cig/api.env
    environment:
      NEO4J_PASSWORD: $${NEO4J_PASSWORD}
    depends_on:
      neo4j:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:${api_container_port}/api/v1/health >/dev/null"]
      interval: 30s
      timeout: 10s
      retries: 5

  caddy:
    image: caddy:2.8-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /opt/cig/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    depends_on:
      api:
        condition: service_healthy

volumes:
  neo4j_data:
  caddy_data:
  caddy_config:
COMPOSE

docker compose -f "$COMPOSE_FILE" --env-file "$API_ENV_FILE" up -d --remove-orphans --pull always

wait_for_url() {
  local label="$1"
  local url="$2"
  local attempts="$${3:-60}"
  local delay_seconds="$${4:-10}"

  for attempt in $(seq 1 "$attempts"); do
    if curl -fsS "$url" >/dev/null; then
      echo "$label ready"
      return 0
    fi

    echo "Waiting for $label ($attempt/$attempts)"
    sleep "$delay_seconds"
  done

  echo "$label did not become ready in time" >&2
  docker compose -f "$COMPOSE_FILE" --env-file "$API_ENV_FILE" ps >&2 || true
  docker compose -f "$COMPOSE_FILE" --env-file "$API_ENV_FILE" logs --no-color --tail 200 >&2 || true
  exit 1
}

wait_for_url \
  "API health endpoint" \
  "http://127.0.0.1:${api_container_port}/api/v1/health"

docker image prune -f >/dev/null
REFRESH

chmod +x /usr/local/bin/cig-api-refresh

cat > /etc/systemd/system/cig-api.service <<'SERVICE'
[Unit]
Description=CIG API host stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/cig-api-refresh
ExecStop=/usr/bin/docker compose -f /opt/cig/docker-compose.yml --env-file /opt/cig/api.env down
TimeoutStartSec=1200

[Install]
WantedBy=multi-user.target
SERVICE

echo "$API_IMAGE_URI" > /opt/cig/api-image-uri
chmod 600 /opt/cig/api-image-uri

systemctl daemon-reload
systemctl enable --now cig-api

echo "CIG API host bootstrap complete"
