{
  "name": "@cig/infra",
  "version": "0.1.2",
  "description": "CIG Infrastructure Deployment Wrapper - provider-agnostic layer for AWS and GCP deployments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cig-infra": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./gcp": {
      "import": "./dist/gcp/index.js",
      "require": "./dist/gcp/index.js",
      "types": "./dist/gcp/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .sst",
    "diff:api:prod": "pnpm exec sst diff --stage production",
    "deploy:api:prod": "pnpm exec sst deploy --stage production --yes",
    "bootstrap:api:prod": "INFRA_API_BOOTSTRAP_ONLY=true pnpm exec sst deploy --stage production --yes",
    "bootstrap:api:pipelines": "INFRA_CREATE_PIPELINES=true pnpm exec sst deploy --stage production --yes"
  },
  "dependencies": {
    "@lsts_tech/infra": "*",
    "@pulumi/aws": "^6.83.2",
    "@pulumi/pulumi": "^3.226.0",
    "sst": "^3.19.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
