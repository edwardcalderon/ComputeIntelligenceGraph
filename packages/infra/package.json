{
  "name": "@cig/infra",
  "version": "0.1.2",
  "description": "CIG Infrastructure Deployment Wrapper - wraps @lsts_tech/infra for AWS deployments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cig-infra": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lsts_tech/infra": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
