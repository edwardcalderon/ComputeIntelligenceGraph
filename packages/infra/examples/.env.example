# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=default

# Authentik Configuration
AUTHENTIK_DOMAIN=auth.example.com
AUTHENTIK_ADMIN_EMAIL=admin@example.com
# AUTHENTIK_VPC_ID=vpc-12345678       # optional
# AUTHENTIK_SUBNET_ID=subnet-12345678 # optional

# Dashboard Configuration
DASHBOARD_BUILD_PATH=./apps/dashboard/.next
# DASHBOARD_DOMAIN=dashboard.example.com # optional
DASHBOARD_AUTHENTIK_INTEGRATION=true

# IAC Module Configuration
IAC_MODULES_PATH=../iac
IAC_NETWORKING_MODULE=networking
IAC_COMPUTE_MODULE=compute

# Logging
LOG_LEVEL=info
LOG_TIMESTAMPS=true
