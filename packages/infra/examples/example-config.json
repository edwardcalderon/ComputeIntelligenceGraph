{
  "aws": {
    "region": "us-east-1",
    "accountId": "123456789012",
    "profile": "default"
  },
  "authentik": {
    "domain": "auth.example.com",
    "adminEmail": "admin@example.com",
    "vpcId": "vpc-12345678",
    "subnetId": "subnet-12345678"
  },
  "dashboard": {
    "buildPath": "./apps/dashboard/.next",
    "domain": "dashboard.example.com",
    "authentikIntegration": true
  },
  "api": {
    "domain": "api.cig.technology",
    "region": "us-east-1",
    "imageRepository": "cig-api-production",
    "containerPort": 8080,
    "cpu": 512,
    "memoryMiB": 1024,
    "desiredCount": 1,
    "createPipeline": false,
    "corsOrigins": ["https://app.cig.lat", "https://cig.lat"],
    "databaseUrlSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/database-url",
    "jwtSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/jwt-secret",
    "authentikSecretRefs": {
      "issuerUrlSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/authentik-issuer",
      "jwksUriSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/authentik-jwks",
      "tokenEndpointSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/authentik-token",
      "oidcClientIdSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/oidc-client-id",
      "oidcClientSecretSecretArn": "arn:aws:secretsmanager:us-east-1:123456789012:secret:cig/prod/api/oidc-client-secret"
    }
  },
  "iac": {
    "modulesPath": "packages/iac",
    "networkingModule": "networking",
    "computeModule": "compute"
  },
  "logging": {
    "level": "info",
    "timestamps": true
  }
}
