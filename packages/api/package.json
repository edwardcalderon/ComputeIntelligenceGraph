{
  "name": "@cig/api",
  "version": "0.2.0",
  "description": "CIG REST/GraphQL API server",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build && node scripts/copy-migrations.mjs",
    "dev": "pnpm build && concurrently --names \"tsc,api\" --prefix-colors \"cyan.bold,green.bold\" \"tsc --watch\" \"node --watch --env-file=../../.env dist/index.js\"",
    "start": "node dist/index.js",
    "migrate:up": "pnpm build && node dist/migrate.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1009.0",
    "@cig/auth": "workspace:*",
    "@cig/discovery": "workspace:*",
    "@cig/graph": "workspace:*",
    "@escape.tech/graphql-armor-cost-limit": "^2.0.0",
    "@escape.tech/graphql-armor-max-depth": "^2.0.0",
    "@fastify/cors": "^8.0.0",
    "@fastify/websocket": "^8.3.1",
    "@supabase/supabase-js": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "fastify": "^4.0.0",
    "fastify-rate-limit": "npm:@fastify/rate-limit@9.1.0",
    "graphql": "^16.0.0",
    "graphql-yoga": "^5.0.0",
    "jose": "^5.2.3",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.11.3",
    "pino": "^8.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.18.1",
    "fast-check": "^3.23.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
