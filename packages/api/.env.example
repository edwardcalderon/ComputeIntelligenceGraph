# Generated by @edcalderon/versioning workspace-env. Do not edit directly.
# Example env for target api

# Authentik OIDC issuer URL
AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/cig/
# Authentik JWKS endpoint for ID token signature verification
AUTHENTIK_JWKS_URI=https://auth.example.com/application/o/cig/jwks/
# Authentik OIDC token endpoint
AUTHENTIK_TOKEN_ENDPOINT=https://auth.example.com/application/o/token/
# Cartography service URL
CARTOGRAPHY_URL=http://localhost:8001
# Chroma vector database URL
CHROMA_URL=http://localhost:8000
# Comma-separated allowed origins for the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Discovery interval in minutes
DISCOVERY_INTERVAL_MINUTES=5
# Discovery interval in milliseconds
DISCOVERY_INTERVAL_MS=300000
# API host binding
HOST=0.0.0.0
# JWT signing secret
JWT_SECRET=change-me-in-production
# Application log level
LOG_LEVEL=info
# Neo4j database name
NEO4J_DATABASE=neo4j
# Neo4j password
NEO4J_PASSWORD=neo4j
# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687
# Neo4j username
NEO4J_USER=neo4j
# OIDC client ID registered in Authentik
OIDC_CLIENT_ID=your-oidc-client-id
# OIDC client secret
OIDC_CLIENT_SECRET=your-oidc-client-secret
# OIDC redirect URI for the API callback
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback
# OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key
# API port
PORT=8080
# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
